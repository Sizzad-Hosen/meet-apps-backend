NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meet_apps

JWT_SECRET=replace_with_a_long_secure_secret
EXPIRE_IN=1d
REFRESH_TOKEN_SECRET=replace_with_a_second_long_secure_secret
REFRESH_TOKEN_EXPIRES_IN=7d
RESET_PASS_TOKEN=reset_secret
RESET_PASS_TOKEN_EXPIRES_IN=15m
RESET_PASS_URL=http://localhost:3000/reset-password

SALT_ROUND=10
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=http://localhost:7880

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_BUCKET=replace_me
