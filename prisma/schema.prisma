// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum MeetingStatus {
  waiting
  active
  ended
}

enum MeetingType {
  instant
  scheduled
}

enum ParticipantRole {
  host
  cohost
  guest
}

enum ParticipantStatus {
  waiting
  admitted
  denied
  left
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  password  String?
  googleId  String?  @unique @map("google_id")
  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(USER)

  isVerified          Boolean              @default(false) @map("is_verified")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  meetings            Meeting[]
  meetingParticipants MeetingParticipant[]
  screenShares        ScreenShare[]
  breakoutMessages    BreakoutMessage[]
  pollVotes           PollVote[]

  @@map("users")
}

model Meeting {
  id                String        @id @default(uuid()) @db.Uuid
  title             String        @db.VarChar(255)
  join_code         String        @unique @db.VarChar(12)
  host_id           String        @db.Uuid
  user              User          @relation(fields: [host_id], references: [id])
  livekit_room_name String        @unique
  status            MeetingStatus @default(waiting)
  type              MeetingType   @default(instant)

  scheduled_at DateTime?
  started_at   DateTime?
  ended_at     DateTime?

  waiting_room_on            Boolean @default(true)
  password_hash              String?
  max_participants           Int     @default(100)
  allow_screenshare          Boolean @default(true)
  screenshare_needs_approval Boolean @default(false)
  is_recorded                Boolean @default(false)

  created_at          DateTime             @default(now())
  meetingParticipants MeetingParticipant[]
  screenShares        ScreenShare[]
  recordings          Recording[]
  breakoutRooms       BreakoutRoom[]
  breakoutMessages    BreakoutMessage[]
  polls               Poll[]

  @@map("meetings")
  @@index([host_id, status])
  @@index([status, created_at])
}

// Meeting Participants

model MeetingParticipant {
  id               String  @id @default(uuid()) @db.Uuid
  meeting_id       String  @db.Uuid
  user_id          String  @db.Uuid
  breakout_room_id String? @db.Uuid

  role   ParticipantRole   @default(guest)
  status ParticipantStatus @default(waiting)

  livekit_token     String?
  is_muted          Boolean   @default(false)
  is_video_off      Boolean   @default(false)
  is_screen_sharing Boolean   @default(false)
  hand_raised       Boolean   @default(false)
  joined_at         DateTime?
  left_at           DateTime?

  // Relations
  meeting      Meeting       @relation(fields: [meeting_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id])
  breakoutRoom BreakoutRoom? @relation(fields: [breakout_room_id], references: [id])

  // A user can only appear once per meeting
  @@unique([meeting_id, user_id])
  @@index([meeting_id, status])
  @@index([user_id, meeting_id])
  @@index([breakout_room_id])
  @@map("meeting_participants")
}

model ScreenShare {
  id String @id @default(uuid()) @db.Uuid

  meeting_id String @db.Uuid
  user_id    String @db.Uuid

  meeting Meeting @relation(fields: [meeting_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meeting_id, user_id])
  @@index([meeting_id])
  @@index([user_id])
  @@map("screenShare")
}

model Recording {
  id               String          @id @default(uuid()) @db.Uuid
  meeting_id       String          @db.Uuid
  egress_id        String
  s3_key           String?
  transcript_url   String?
  status           RecordingStatus @default(recording)
  duration_seconds Int?
  started_at       DateTime        @default(now())
  ended_at         DateTime?
  created_at       DateTime        @default(now())

  meeting Meeting @relation(fields: [meeting_id], references: [id])

  @@unique([egress_id])
  @@index([meeting_id])
  @@map("recordings")
}

enum RecordingStatus {
  recording
  completed
  failed
}

enum BreakoutRoomStatus {
  open
  closed
}

model BreakoutRoom {
  id         String             @id @default(uuid()) @db.Uuid
  meeting_id String             @db.Uuid
  name       String             @db.VarChar(100)
  status     BreakoutRoomStatus @default(open)
  created_at DateTime           @default(now())

  meeting      Meeting              @relation(fields: [meeting_id], references: [id])
  participants MeetingParticipant[]
  messages     BreakoutMessage[]

  @@map("breakout_rooms")
  @@index([meeting_id, status])
}

model BreakoutMessage {
  id               String   @id @default(uuid()) @db.Uuid
  meeting_id       String   @db.Uuid
  breakout_room_id String?  @db.Uuid
  sender_id        String   @db.Uuid
  content          String   @db.Text
  created_at       DateTime @default(now())

  meeting      Meeting       @relation(fields: [meeting_id], references: [id])
  breakoutRoom BreakoutRoom? @relation(fields: [breakout_room_id], references: [id])
  sender       User          @relation(fields: [sender_id], references: [id])

  @@map("breakout_messages")
  @@index([meeting_id, created_at])
  @@index([breakout_room_id, created_at])
}

model Poll {
  id         String    @id @default(uuid()) @db.Uuid
  meeting_id String    @db.Uuid
  question   String    @db.VarChar(255)
  is_closed  Boolean   @default(false)
  created_at DateTime  @default(now())
  closed_at  DateTime?

  meeting Meeting      @relation(fields: [meeting_id], references: [id])
  options PollOption[]
  votes   PollVote[]

  @@map("polls")
  @@index([meeting_id, created_at])
}

model PollOption {
  id      String @id @default(uuid()) @db.Uuid
  poll_id String @db.Uuid
  text    String @db.VarChar(255)

  poll  Poll       @relation(fields: [poll_id], references: [id])
  votes PollVote[]

  @@map("poll_options")
  @@index([poll_id])
}

model PollVote {
  id         String   @id @default(uuid()) @db.Uuid
  poll_id    String   @db.Uuid
  option_id  String   @db.Uuid
  voter_id   String   @db.Uuid
  created_at DateTime @default(now())

  poll   Poll       @relation(fields: [poll_id], references: [id])
  option PollOption @relation(fields: [option_id], references: [id])
  voter  User       @relation(fields: [voter_id], references: [id])

  @@unique([poll_id, voter_id])
  @@index([option_id])
  @@map("poll_votes")
}
